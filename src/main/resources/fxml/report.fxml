<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kelompok.moodflow.controller.ReportController"
      style="-fx-background-color: #F8F9FA;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <!-- Header -->
    <Label text="📊 Mood Analytics Report" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2D2D2D;" />
    <Label text="Visualize your mood patterns and emotional journey" style="-fx-text-fill: #8B8B8B; -fx-font-size: 13;" />

    <Separator style="-fx-background-color: #E8E8E8;" />

    <!-- Pie Chart Container -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
        <Label text="🎯 Mood Distribution" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #6C63FF;" />
        <PieChart fx:id="moodPieChart" prefHeight="400" prefWidth="700" style="-fx-background-color: transparent;" />

        <Label text="Your mood data helps understand your emotional patterns" style="-fx-text-fill: #AAAAAA; -fx-font-size: 11; -fx-padding: 10 0 0 0;" />
    </VBox>
</VBox>