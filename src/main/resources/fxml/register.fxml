<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #6C63FF, #3F3D9E);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kelompok.moodflow.controller.RegisterController">

    <center>
        <!-- Card Container - Otomatis di tengah -->
        <VBox alignment="CENTER" maxWidth="400.0" maxHeight="520.0"
              style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);">

            <padding>
                <Insets bottom="35" left="35" right="35" top="35" />
            </padding>

            <children>
                <!-- Logo -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="🌊" style="-fx-font-size: 36;" />
                    <Label text="MoodFlow" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #6C63FF;" />
                </HBox>

                <Label text="Join us to track your mood!" style="-fx-font-size: 12; -fx-text-fill: #888;">
                    <VBox.margin>
                        <Insets bottom="25" />
                    </VBox.margin>
                </Label>

                <!-- Full Name -->
                <VBox spacing="6">
                    <Label text="Full Name" style="-fx-text-fill: #555; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="fullNameField" promptText="John Doe"
                               style="-fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12;" />
                </VBox>

                <!-- Username -->
                <VBox spacing="6">
                    <VBox.margin>
                        <Insets top="15" />
                    </VBox.margin>
                    <Label text="Username" style="-fx-text-fill: #555; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="usernameField" promptText="johndoe"
                               style="-fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12;" />
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <VBox.margin>
                        <Insets top="15" />
                    </VBox.margin>
                    <Label text="Password" style="-fx-text-fill: #555; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <PasswordField fx:id="passwordField" promptText="••••••••"
                                   style="-fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12;" />
                </VBox>

                <!-- Register Button -->
                <Button fx:id="registerButton" text="SIGN UP"
                        style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;"
                        prefWidth="200" prefHeight="44">
                    <VBox.margin>
                        <Insets top="25" bottom="15" />
                    </VBox.margin>
                </Button>

                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Already have an account?" style="-fx-text-fill: #888;" />
                    <Hyperlink fx:id="loginLink" text="Login" style="-fx-text-fill: #6C63FF; -fx-underline: true; -fx-cursor: hand;" />
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>