<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #6C63FF, #3F3D9E);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kelompok.moodflow.controller.LoginController">

    <center>
        <!-- Card Container - Otomatis di tengah karena pakai BorderPane center -->
        <VBox alignment="CENTER" maxWidth="380.0" maxHeight="450.0"
              style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);">

            <padding>
                <Insets bottom="35" left="35" right="35" top="35" />
            </padding>

            <children>
                <!-- Logo dengan Icon -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="🌊" style="-fx-font-size: 36;" />
                    <Label text="MoodFlow" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #6C63FF;" />
                </HBox>

                <Label text="Productivity meets Mood Tracking" style="-fx-font-size: 12; -fx-text-fill: #888;">
                    <VBox.margin>
                        <Insets bottom="30" />
                    </VBox.margin>
                </Label>

                <!-- Email / Username Field -->
                <VBox spacing="6" VBox.vgrow="NEVER">
                    <Label text="Email / Username" style="-fx-text-fill: #555; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="emailField" promptText="your@email.com" style="-fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12;" />
                </VBox>

                <!-- Password Field -->
                <VBox spacing="6" VBox.vgrow="NEVER">
                    <VBox.margin>
                        <Insets top="15" />
                    </VBox.margin>
                    <Label text="Password" style="-fx-text-fill: #555; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12;" />
                </VBox>

                <!-- Login Button -->
                <Button fx:id="loginButton" text="LOGIN"
                        style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;"
                        prefWidth="200" prefHeight="44">
                    <VBox.margin>
                        <Insets top="25" bottom="15" />
                    </VBox.margin>
                </Button>

                <!-- Register Link -->
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Don't have an account?" style="-fx-text-fill: #888;" />
                    <Hyperlink fx:id="registerLink" text="Sign Up" style="-fx-text-fill: #6C63FF; -fx-underline: true; -fx-cursor: hand;" />
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>