<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" styleClass="main-window" style="-fx-background-color: #F8F9FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kelompok.moodflow.controller.DashboardController">

    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: linear-gradient(to right, #6C63FF, #7C83FD); -fx-padding: 15 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" alignment="CENTER_LEFT" spacing="20">
            <Label text="🌊 MoodFlow" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="15">
                <Label fx:id="userLabel" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30; -fx-padding: 8 16; -fx-text-fill: white; -fx-font-weight: bold;" />
                <Button fx:id="logoutButton" text="🚪 Logout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-width: 2; -fx-border-radius: 30; -fx-padding: 8 20; -fx-cursor: hand;" />
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: white; -fx-pref-width: 260; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 2, 0);">
            <VBox style="-fx-padding: 30 20 20 24;">
                <Label text="✨ MENU" style="-fx-text-fill: #6C63FF; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1;" />
                <Label text="Main Navigation" style="-fx-text-fill: #AAAAAA; -fx-font-size: 10;" />
            </VBox>

            <Button fx:id="dashboardBtn" text="🏠 Dashboard" style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-padding: 12 20; -fx-alignment: CENTER_LEFT; -fx-background-radius: 12; -fx-font-size: 14; -fx-cursor: hand;" />
            <Button fx:id="tasksBtn" text="📋 My Tasks" style="-fx-background-color: transparent; -fx-text-fill: #5A5A5A; -fx-padding: 12 20; -fx-alignment: CENTER_LEFT; -fx-background-radius: 12; -fx-font-size: 14; -fx-cursor: hand;" />
            <Button fx:id="moodBtn" text="😊 Mood Tracker" style="-fx-background-color: transparent; -fx-text-fill: #5A5A5A; -fx-padding: 12 20; -fx-alignment: CENTER_LEFT; -fx-background-radius: 12; -fx-font-size: 14; -fx-cursor: hand;" />
            <Button fx:id="reportBtn" text="📊 Report" style="-fx-background-color: transparent; -fx-text-fill: #5A5A5A; -fx-padding: 12 20; -fx-alignment: CENTER_LEFT; -fx-background-radius: 12; -fx-font-size: 14; -fx-cursor: hand;" />

            <Region VBox.vgrow="ALWAYS" />

            <!-- Footer Sidebar -->
            <VBox style="-fx-padding: 20; -fx-border-color: #F0F0F0 transparent transparent transparent; -fx-border-width: 1;">
                <Label text="💡 Tip" style="-fx-text-fill: #6C63FF; -fx-font-size: 11; -fx-font-weight: bold;" />
                <Label text="Track your mood daily\nto see your progress!" style="-fx-text-fill: #AAAAAA; -fx-font-size: 10;" wrapText="true" />
            </VBox>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F8F9FA; -fx-padding: 25;">
            <VBox spacing="25">
                <VBox spacing="8">
                    <Label text="✨ Welcome Back!" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2D2D2D;" />
                    <Label text="Let's make today productive and joyful" style="-fx-text-fill: #8B8B8B; -fx-font-size: 14;" />
                </VBox>

                <HBox spacing="20" alignment="CENTER">
                    <VBox fx:id="totalTasksCard" alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="stat-card">
                        <Label text="📋" style="-fx-font-size: 40;" />
                        <Label fx:id="totalTasksLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #6C63FF;" />
                        <Label text="Total Tasks" style="-fx-font-size: 14; -fx-text-fill: #8B8B8B;" />
                    </VBox>

                    <VBox fx:id="completedTasksCard" alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="stat-card">
                        <Label text="✅" style="-fx-font-size: 40;" />
                        <Label fx:id="completedTasksLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #4CAF50;" />
                        <Label text="Completed" style="-fx-font-size: 14; -fx-text-fill: #8B8B8B;" />
                    </VBox>

                    <VBox fx:id="totalMoodsCard" alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="stat-card">
                        <Label text="😊" style="-fx-font-size: 40;" />
                        <Label fx:id="avgMoodLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF9800;" />
                        <Label text="Mood Logs" style="-fx-font-size: 14; -fx-text-fill: #8B8B8B;" />
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>